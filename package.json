{
  "name": "security-plus-study-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:beta": "vite --mode beta",
    "build": "vite build",
    "build:beta": "vite build --mode beta",
    "preview": "vite preview",
    "test": "node --test tests/unit/*.test.js",
    "test:e2e": "playwright test",
    "test:beta": "playwright test --config playwright.beta.config.js",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.js",
    "validate": "npm test && npm run build && npm run test:e2e",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@capacitor/cli": "^8.4.0",
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.16"
  }
}
